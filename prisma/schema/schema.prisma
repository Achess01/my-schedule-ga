// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(150)
  firstname String   @db.VarChar(100)
  lastname  String   @db.VarChar(100)
  password  String   @db.VarChar(100)
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    Int
  createdAt DateTime @default(now())
  student   Student? @relation(fields: [studentId], references: [studentId])
  studentId Int?     @unique
  StudentGeneratedSchedule       StudentGeneratedSchedule[]
  StudentGeneratedScheduleHeader StudentGeneratedScheduleHeader[]
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String   @db.VarChar(255)
  createdAt   DateTime @default(now())
  User        User[]
}

model Career {
  careerId  Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())
  Pensum    Pensum[]
}

model Course {
  courseCode     Int            @id
  name           String         @db.VarChar(255)
  defaultCredits Int
  PensumCourse   PensumCourse[]
}

model StudyArea {
  id           Int            @id @default(autoincrement())
  name         String         @unique @db.VarChar(100)
  description  String         @db.VarChar(255)
  pensumCourse PensumCourse[]
}

model Pensum {
  pensumId      Int             @id @default(autoincrement())
  name          String          @unique @db.VarChar(100)
  creditsNeeded Int             @default(0)
  career        Career          @relation(fields: [careerId], references: [careerId])
  careerId      Int
  createdAt     DateTime        @default(now())
  PensumCourse  PensumCourse[]
  StudentPensum StudentPensum[]
}

model PensumCourse {
  pensumCourseId Int                        @id @default(autoincrement())
  pensum         Pensum                     @relation(fields: [pensumId], references: [pensumId])
  pensumId       Int
  course         Course                     @relation(fields: [courseCode], references: [courseCode])
  courseCode     Int
  studyArea      StudyArea                  @relation(fields: [studyAreaId], references: [id])
  studyAreaId    Int
  credits        Int
  requiredCreds  Int
  isMandatory    Boolean
  prerequisites  PensumCoursePrerequisite[] @relation("PensumCoursePrerequisiteCourse")
  postrequisites PensumCoursePrerequisite[] @relation("PensumCoursePrerequisitePrerequisite")
  semester       Int                        @default(1)
  StudentGrade   StudentGrade[]
}

model PensumCoursePrerequisite {
  pensumCourse   PensumCourse @relation("PensumCoursePrerequisiteCourse", fields: [pensumCourseId], references: [pensumCourseId], onDelete: Cascade)
  pensumCourseId Int
  prerequisite   PensumCourse @relation("PensumCoursePrerequisitePrerequisite", fields: [prerequisiteId], references: [pensumCourseId], onDelete: Cascade)
  prerequisiteId Int

  @@id([pensumCourseId, prerequisiteId])
}

enum GradeType {
  FIRST_SEMESTER     @map("Primer Semestre")
  SECOND_SEMESTER    @map("Segundo Semestre")
  VACATIONS_JUNE     @map("EDV Junio")
  VACATIONS_DECEMBER @map("EDV Diciembre")
}

model Student {
  studentId     Int             @id
  user          User?
  entryDate     DateTime        @db.Date
  firstname     String          @db.VarChar(100)
  lastname      String          @db.VarChar(100)
  createdAt     DateTime        @default(now())
  StudentPensum StudentPensum[]
}

model StudentPensum {
  studentPensumId Int            @id @default(autoincrement())
  student         Student        @relation(fields: [studentId], references: [studentId])
  studentId       Int
  pensum          Pensum         @relation(fields: [pensumId], references: [pensumId])
  pensumId        Int
  createdAt       DateTime       @default(now())
  StudentGrade    StudentGrade[]
  StudentGeneratedSchedule       StudentGeneratedSchedule[]
  StudentGeneratedScheduleHeader StudentGeneratedScheduleHeader[]

  @@unique([studentId, pensumId])
}

model StudentGrade {
  studentGradeId  Int           @id @default(autoincrement())
  studentPensum   StudentPensum @relation(fields: [studentPensumId], references: [studentPensumId])
  studentPensumId Int
  pensumCourse    PensumCourse  @relation(fields: [pensumCourseId], references: [pensumCourseId])
  pensumCourseId  Int
  isApproved      Boolean
  gradeType       GradeType
  grade           Int
  createdAt       DateTime      @default(now())
}

model StudentGeneratedScheduleHeader {
  studentGeneratedScheduleHeaderId Int      @id @default(autoincrement())
  name                             String   @db.VarChar(150)
  generatedScheduleId              String   @db.VarChar(50)
  createdAt                        DateTime @default(now())
  studentPensum                    StudentPensum @relation(fields: [studentPensumId], references: [studentPensumId])
  studentPensumId                  Int
  owner                            User     @relation(fields: [userId], references: [id])
  userId                           Int
  schedules                        StudentGeneratedSchedule[]
}

model StudentGeneratedSchedule {
  studentGeneratedScheduleId Int    @id @default(autoincrement())
  scheduleConfigId           String @db.VarChar(50)
  isBest                     Boolean
  active                     Boolean   @default(true)
  periodDurationM            Int
  morningStartTime           DateTime
  morningEndTime             DateTime
  afternoonStartTime         DateTime
  afternoonEndTime           DateTime
  createdAt                  DateTime  @default(now())
  owner                      User      @relation(fields: [userId], references: [id])
  userId                     Int
  header                     StudentGeneratedScheduleHeader @relation(fields: [studentGeneratedScheduleHeaderId], references: [studentGeneratedScheduleHeaderId])
  studentGeneratedScheduleHeaderId Int
  studentPensum              StudentPensum @relation(fields: [studentPensumId], references: [studentPensumId])
  studentPensumId            Int
  items                      StudentGeneratedScheduleItem[]
}

model StudentGeneratedScheduleItem {
  studentGeneratedScheduleItemId Int    @id @default(autoincrement())
  generatedScheduleItemId        String @db.VarChar(50)
  configCourseId                 String @db.VarChar(50)
  courseCode                     Int
  courseName                     String  @db.VarChar(255)
  sectionIndex                   Int
  sessionType                    String  @db.VarChar(20)
  dayIndex                       Int
  startSlot                      Int
  periodCount                    Int
  requireClassroom               Boolean
  classroomName                  String? @db.VarChar(150)
  professorName                  String  @db.VarChar(150)
  isMandatory                    Boolean
  studentGeneratedSchedule       StudentGeneratedSchedule @relation(fields: [studentGeneratedScheduleId], references: [studentGeneratedScheduleId], onDelete: Cascade)
  studentGeneratedScheduleId     Int
}
